<idea-plugin>
    <!-- This file is loaded only when the Terraform plugin is available -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- Associate .hcl files with HCL file type from Terraform plugin -->
        <fileType.fileNameMatcher 
            filetype="HCL"
            implementationClass="com.intellij.openapi.fileTypes.ExtensionFileNameMatcher">
            <extensions>hcl</extensions>
        </fileType.fileNameMatcher>
    </extensions>
</idea-plugin>
